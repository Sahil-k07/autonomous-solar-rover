<?xml version="1.0"?>
<robot name="solar_rover_pro">
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed"><parent link="base_footprint"/><child link="base_link"/></joint>

  <link name="base_link">
    <visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/base_link.stl" scale="0.012 0.012 0.012"/></geometry></visual>
    <collision><origin xyz="0 0 0.75"/><geometry><box size="1.2 0.4 0.2"/></geometry></collision>
    <inertial><mass value="30.0"/><inertia ixx="5.0" ixy="0" ixz="0" iyy="10.0" iyz="0" izz="10.0"/></inertial>
  </link>

  <link name="wheel_fl"><visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/wheel.stl" scale="0.012 0.012 0.012"/></geometry></visual><collision><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.32" length="0.2"/></geometry></collision><inertial><mass value="2.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial></link>
  <joint name="wheel_fl_joint" type="continuous"><parent link="base_link"/><child link="wheel_fl"/><origin xyz="0.7 0.7 0.32"/><axis xyz="0 1 0"/></joint>

  <link name="wheel_fr"><visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/wheel.stl" scale="0.012 0.012 0.012"/></geometry></visual><collision><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.32" length="0.2"/></geometry></collision><inertial><mass value="2.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial></link>
  <joint name="wheel_fr_joint" type="continuous"><parent link="base_link"/><child link="wheel_fr"/><origin xyz="0.7 -0.7 0.32"/><axis xyz="0 1 0"/></joint>

  <link name="wheel_ml"><visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/wheel.stl" scale="0.012 0.012 0.012"/></geometry></visual><collision><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.32" length="0.2"/></geometry></collision><inertial><mass value="2.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial></link>
  <joint name="wheel_ml_joint" type="continuous"><parent link="base_link"/><child link="wheel_ml"/><origin xyz="0 0.7 0.32"/><axis xyz="0 1 0"/></joint>

  <link name="wheel_mr"><visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/wheel.stl" scale="0.012 0.012 0.012"/></geometry></visual><collision><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.32" length="0.2"/></geometry></collision><inertial><mass value="2.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial></link>
  <joint name="wheel_mr_joint" type="continuous"><parent link="base_link"/><child link="wheel_mr"/><origin xyz="0 -0.7 0.32"/><axis xyz="0 1 0"/></joint>

  <link name="wheel_rl"><visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/wheel.stl" scale="0.012 0.012 0.012"/></geometry></visual><collision><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.32" length="0.2"/></geometry></collision><inertial><mass value="2.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial></link>
  <joint name="wheel_rl_joint" type="continuous"><parent link="base_link"/><child link="wheel_rl"/><origin xyz="-0.7 0.7 0.32"/><axis xyz="0 1 0"/></joint>

  <link name="wheel_rr"><visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/wheel.stl" scale="0.012 0.012 0.012"/></geometry></visual><collision><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.32" length="0.2"/></geometry></collision><inertial><mass value="2.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial></link>
  <joint name="wheel_rr_joint" type="continuous"><parent link="base_link"/><child link="wheel_rr"/><origin xyz="-0.7 -0.7 0.32"/><axis xyz="0 1 0"/></joint>

  <link name="arm_base">
    <visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/arm_base.stl" scale="0.012 0.012 0.012"/></geometry></visual>
    <collision><geometry><cylinder radius="0.05" length="0.05"/></geometry></collision>
    <inertial><mass value="1.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="arm_base_joint" type="revolute"><parent link="base_link"/><child link="arm_base"/><origin xyz="0.2 0 1.0"/><axis xyz="0 0 1"/><limit lower="-3.14" upper="3.14" effort="5000" velocity="1.0"/></joint>

  <link name="arm_lower">
    <visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/arm_lower.stl" scale="0.012 0.012 0.012"/></geometry></visual>
    <collision><geometry><cylinder radius="0.05" length="0.05"/></geometry></collision>
    <inertial><mass value="1.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="arm_shoulder_joint" type="revolute"><parent link="arm_base"/><child link="arm_lower"/><origin xyz="0 0 0.3" rpy="0 -1.0 0"/><axis xyz="0 1 0"/><limit lower="-1.5" upper="1.57" effort="5000" velocity="1.0"/></joint>

  <link name="arm_upper">
    <visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/arm_upper.stl" scale="0.012 0.012 0.012"/></geometry></visual>
    <collision><geometry><cylinder radius="0.05" length="0.05"/></geometry></collision>
    <inertial><mass value="1.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="arm_elbow_joint" type="revolute"><parent link="arm_lower"/><child link="arm_upper"/><origin xyz="0 0 0.93" rpy="0 1.2 0"/><axis xyz="0 1 0"/><limit lower="-2.0" upper="2.0" effort="5000" velocity="1.0"/></joint>

  <link name="brush">
    <visual><geometry><mesh filename="file:///home/sam_k/ros2_sam/src/solar_rover_description/meshes/brush.stl" scale="0.012 0.012 0.012"/></geometry></visual>
    <collision><geometry><cylinder radius="0.05" length="0.05"/></geometry></collision>
    <inertial><mass value="1.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="brush_wrist_joint" type="continuous"><parent link="arm_upper"/><child link="brush"/><origin xyz="0 0 0.73" rpy="0 -1.57 0"/><axis xyz="0 1 0"/></joint>

  <link name="lidar_link">
    <visual><origin xyz="0 0 0"/><geometry><cylinder radius="0.1" length="0.08"/></geometry></visual>
  </link>
  <joint name="lidar_joint" type="fixed"><parent link="base_link"/><child link="lidar_link"/><origin xyz="0.75 0 1.05"/></joint>

  <gazebo>
    <plugin name='diff_drive' filename='libgazebo_ros_diff_drive.so'>
      <num_wheel_pairs>3</num_wheel_pairs>
      <left_joint>wheel_fl_joint</left_joint><left_joint>wheel_ml_joint</left_joint><left_joint>wheel_rl_joint</left_joint>
      <right_joint>wheel_fr_joint</right_joint><right_joint>wheel_mr_joint</right_joint><right_joint>wheel_rr_joint</right_joint>
      <wheel_separation>1.4</wheel_separation><wheel_diameter>0.64</wheel_diameter>
      <publish_odom>true</publish_odom><publish_odom_tf>true</publish_odom_tf>
    </plugin>
    <plugin name="shoulder_controller" filename="libgazebo_ros_joint_pose_trajectory.so">
      <ros><remapping>set_joint_trajectory:=shoulder_cmd</remapping></ros>
      <update_rate>20</update_rate><frame_id>base_link</frame_id>
    </plugin>
    <plugin name="elbow_controller" filename="libgazebo_ros_joint_pose_trajectory.so">
      <ros><remapping>set_joint_trajectory:=elbow_cmd</remapping></ros>
      <update_rate>20</update_rate><frame_id>base_link</frame_id>
    </plugin>
    <plugin name="gazebo_ros_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros><remapping>~/out:=joint_states</remapping></ros>
      <update_rate>30</update_rate>
      <joint_name>arm_base_joint</joint_name><joint_name>arm_shoulder_joint</joint_name><joint_name>arm_elbow_joint</joint_name><joint_name>brush_wrist_joint</joint_name>
    </plugin>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor type="ray" name="main_lidar">
      <visualize>true</visualize><update_rate>10</update_rate>
      <ray><scan><horizontal><samples>360</samples><min_angle>-3.14</min_angle><max_angle>3.14</max_angle></horizontal></scan><range><min>0.1</min><max>15.0</max></range></ray>
      <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so"><ros><remapping>~/out:=scan</remapping></ros><output_type>sensor_msgs/LaserScan</output_type><frame_name>lidar_link</frame_name></plugin>
    </sensor>
  </gazebo>

  <gazebo reference="wheel_fl"><mu1>1.0</mu1><mu2>0.1</mu2><material>Gazebo/Black</material></gazebo>
  <gazebo reference="wheel_fr"><mu1>1.0</mu1><mu2>0.1</mu2><material>Gazebo/Black</material></gazebo>
  <gazebo reference="wheel_ml"><mu1>1.0</mu1><mu2>1.0</mu2><material>Gazebo/Black</material></gazebo> <gazebo reference="wheel_mr"><mu1>1.0</mu1><mu2>1.0</mu2><material>Gazebo/Black</material></gazebo>
  <gazebo reference="wheel_rl"><mu1>1.0</mu1><mu2>0.1</mu2><material>Gazebo/Black</material></gazebo>
  <gazebo reference="wheel_rr"><mu1>1.0</mu1><mu2>0.1</mu2><material>Gazebo/Black</material></gazebo>

  <gazebo reference="base_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="arm_base"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="arm_lower"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="arm_upper"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="brush"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="lidar_link"><material>Gazebo/White</material></gazebo>
</robot>